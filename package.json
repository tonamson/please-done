{
  "name": "please-done",
  "version": "2.7.1",
  "description": "Cross-platform AI coding skills — Claude Code, Codex, Gemini CLI, OpenCode, Copilot",
  "bin": {
    "please-done": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "VERSION",
    "CHANGELOG.md",
    "env.example"
  ],
  "engines": {
    "node": ">=16.7.0"
  },
  "scripts": {
    "install:claude": "node bin/install.js --claude",
    "install:codex": "node bin/install.js --codex",
    "install:gemini": "node bin/install.js --gemini",
    "install:opencode": "node bin/install.js --opencode",
    "install:copilot": "node bin/install.js --copilot",
    "install:all": "node bin/install.js --all",
    "uninstall:claude": "node bin/install.js --uninstall --claude",
    "uninstall:codex": "node bin/install.js --uninstall --codex",
    "uninstall:gemini": "node bin/install.js --uninstall --gemini",
    "uninstall:opencode": "node bin/install.js --uninstall --opencode",
    "uninstall:copilot": "node bin/install.js --uninstall --copilot",
    "uninstall:all": "node bin/install.js --uninstall --all",
    "test": "echo \"No tests configured\" && exit 0",
    "eval": "node evals/run.js",
    "eval:trigger": "node evals/run.js --trigger",
    "eval:full": "node evals/run.js --full",
    "eval:compare": "node evals/run.js --compare",
    "eval:view": "promptfoo view",
    "eval:filter": "node evals/run.js --filter-pattern"
  },
  "keywords": [
    "claude-code",
    "codex",
    "gemini-cli",
    "opencode",
    "copilot",
    "ai-skills",
    "cross-platform"
  ],
  "author": "tonamson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonamson/please-done.git"
  }
}
